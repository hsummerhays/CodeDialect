# ── Infrastructure ──────────────────────────────────────────────────────────
# Used by docker-compose and the API connection strings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codedialect
POSTGRES_PORT=5432

REDIS_PORT=6379

# ── Security ─────────────────────────────────────────────────────────────────
# Required in production. Dev uses the value in appsettings.Development.json.
JWT_SECRET=replace-with-a-long-random-string

# ── Docker compose API service ────────────────────────────────────────────────
# Host port the containerized API is exposed on. Local dev uses port 5292 (launchSettings.json).
API_PORT=5187
ASPNETCORE_ENVIRONMENT=Production

# ── Frontend ──────────────────────────────────────────────────────────────────
# In dev the Vite proxy forwards /api → http://localhost:5292, so VITE_API_URL is not needed.
# Set this for production builds pointing at the deployed API.
# VITE_API_URL=https://api.codedialect.com
VITE_PORT=5173
